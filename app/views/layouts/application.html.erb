<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "InlineCRM" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-full">
    <div class="min-h-full">
      <nav class="bg-white border-b border-gray-200">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-14 items-center justify-between">
            <div class="flex items-center gap-8">
              <%= link_to "InlineCRM", root_path, class: "text-lg font-bold text-gray-900" %>
              <div class="flex items-center gap-1">
                <%= link_to "Dashboard", root_path, class: "px-3 py-2 text-sm font-medium rounded-md #{request.path == '/' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" %>
                <%= link_to "Contacts", contacts_path, class: "px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?('/contacts') ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" %>
                <%= link_to "Companies", companies_path, class: "px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?('/companies') ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" %>
                <%= link_to "Pipeline", deals_path, class: "px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?('/deals') ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" %>
                <%= link_to "Activity", activities_path, class: "px-3 py-2 text-sm font-medium rounded-md #{request.path.start_with?('/activities') ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" %>
              </div>
            </div>
          </div>
        </div>
      </nav>

      <% if notice.present? %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
          <div class="rounded-md bg-green-50 p-3">
            <p class="text-sm text-green-700"><%= notice %></p>
          </div>
        </div>
      <% end %>

      <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
