<div class="max-w-xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Deal</h1>

  <%= form_with(model: @deal, class: "space-y-4") do |f| %>
    <% if @deal.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <ul class="text-sm text-red-700">
          <% @deal.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= f.label :stage, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :stage, Deal::STAGES.map { |s| [s.humanize, s] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= f.label :value, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :value, step: "0.01", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= f.label :company_id, "Company", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :company_id, Company.order(:name), :id, :name, { include_blank: "Select a company" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= f.label :contact_id, "Contact", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :contact_id, Contact.order(:first_name), :id, :full_name, { include_blank: "Select a contact" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Create Deal", class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancel", deals_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>
