<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @company.name %></h1>
  <div class="flex gap-2">
    <%= link_to "Back", companies_path, class: "text-sm text-gray-600 hover:text-gray-900 px-3 py-2" %>
    <%= button_to "Delete", company_path(@company), method: :delete, class: "text-sm text-red-600 hover:text-red-800 px-3 py-2", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Details</h2>
      <p class="text-xs text-gray-400 mb-4">Click any field to edit inline</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <%= render EditableFieldComponent.new(record: @company, field: :name, label: "Name") %>
        <%= render EditableFieldComponent.new(record: @company, field: :industry, label: "Industry") %>
        <%= render EditableFieldComponent.new(record: @company, field: :website, label: "Website") %>
        <%= render EditableFieldComponent.new(record: @company, field: :phone, label: "Phone") %>
      </div>
      <div class="mt-4">
        <%= render EditableFieldComponent.new(record: @company, field: :notes, label: "Notes", input_type: :textarea) %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5 mt-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Contacts</h2>
        <%= link_to "Add Contact", new_contact_path(company_id: @company.id), class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      <% @contacts.each do |contact| %>
        <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
          <%= link_to contact.full_name, contact_path(contact), class: "text-sm text-blue-600 hover:text-blue-800" %>
          <span class="text-xs text-gray-500"><%= contact.title %></span>
        </div>
      <% end %>
      <% if @contacts.empty? %>
        <p class="text-sm text-gray-400 py-2">No contacts yet</p>
      <% end %>
    </div>

    <% if @deals.any? %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5 mt-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Deals</h2>
        <% @deals.each do |deal| %>
          <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
            <%= link_to deal.name, deal_path(deal), class: "text-sm text-blue-600 hover:text-blue-800" %>
            <div class="flex items-center gap-3">
              <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-600"><%= deal.stage.humanize %></span>
              <span class="text-sm font-medium text-gray-700"><%= deal.formatted_value %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Activity</h2>
      <div id="activity-feed"
           data-controller="activity-feed"
           data-activity-feed-url-value="<%= feed_activities_path(since: @activities.first&.id || 0) %>">
        <% @activities.each do |activity| %>
          <%= render ActivityEntryComponent.new(activity: activity) %>
        <% end %>
        <% if @activities.empty? %>
          <p class="text-sm text-gray-400 py-4 text-center">No activity yet</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
