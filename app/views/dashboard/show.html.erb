<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
</div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
    <p class="text-sm font-medium text-gray-500">Contacts</p>
    <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @contacts_count %></p>
  </div>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
    <p class="text-sm font-medium text-gray-500">Companies</p>
    <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @companies_count %></p>
  </div>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
    <p class="text-sm font-medium text-gray-500">Active Deals</p>
    <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @deals_count %></p>
  </div>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
    <p class="text-sm font-medium text-gray-500">Pipeline Value</p>
    <p class="mt-1 text-3xl font-semibold text-gray-900">$<%= number_with_delimiter(@pipeline_value.to_i) %></p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Pipeline Overview</h2>
      <div class="space-y-3">
        <% Deal::STAGES.first(4).each do |stage| %>
          <% deals = @deals_by_stage[stage] || [] %>
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-700 w-28"><%= stage.humanize %></span>
            <div class="flex-1 mx-4 bg-gray-100 rounded-full h-2">
              <% max = [@deals_by_stage.values.flatten.size, 1].max %>
              <div class="bg-blue-500 rounded-full h-2" style="width: <%= (deals.size.to_f / max * 100).round %>%"></div>
            </div>
            <span class="text-sm text-gray-500 w-20 text-right"><%= deals.size %> deals</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Activity</h2>
      <div id="activity-feed">
        <% @recent_activities.first(10).each do |activity| %>
          <%= render ActivityEntryComponent.new(activity: activity) %>
        <% end %>
        <% if @recent_activities.empty? %>
          <p class="text-sm text-gray-400 py-4 text-center">No activity yet</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
