<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Contacts</h1>
  <%= link_to "New Contact", new_contact_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700" %>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Phone</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Company</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @contacts.each do |contact| %>
        <tr class="hover:bg-gray-50" id="<%= dom_id(contact) %>">
          <td class="px-6 py-4">
            <%= link_to contact.full_name, contact_path(contact), class: "text-sm font-medium text-blue-600 hover:text-blue-800" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= contact.email %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= contact.phone %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= contact.company&.name %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= contact.title %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
