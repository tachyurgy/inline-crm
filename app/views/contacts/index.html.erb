<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Contacts</h1>
  <div class="flex items-center gap-4">
    <%= form_with url: contacts_path, method: :get, data: { controller: "search", turbo_frame: "contacts-table", turbo_action: "advance" }, class: "relative" do %>
      <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search contacts..."
             class="w-64 pl-9 pr-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
             data-search-target="input" data-action="input->search#search" autocomplete="off">
      <svg class="absolute left-3 top-2.5 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    <% end %>
    <%= link_to "New Contact", new_contact_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700" %>
  </div>
</div>

<%= turbo_frame_tag "contacts-table" do %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Phone</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Company</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @contacts.each do |contact| %>
          <tr class="hover:bg-gray-50" id="<%= dom_id(contact) %>">
            <td class="px-6 py-4">
              <%= link_to contact.full_name, contact_path(contact), class: "text-sm font-medium text-blue-600 hover:text-blue-800", data: { turbo_frame: "_top" } %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= contact.email %></td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= contact.phone %></td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= contact.company&.name %></td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= contact.title %></td>
          </tr>
        <% end %>
        <% if @contacts.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-8 text-center text-sm text-gray-400">No contacts found</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
