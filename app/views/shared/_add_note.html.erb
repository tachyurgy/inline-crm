<div class="mt-4 pt-4 border-t border-gray-100" data-controller="note-form">
  <%= form_with url: url, method: :post, class: "flex gap-2", data: { action: "turbo:submit-end->note-form#reset" } do |f| %>
    <%= f.hidden_field :action, name: "activity[action]", value: "noted" %>
    <input type="text" name="activity[description]" placeholder="Add a note..."
           class="flex-1 border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
           required autocomplete="off" data-note-form-target="input">
    <button type="submit" class="bg-gray-800 text-white px-3 py-1.5 rounded-md text-sm font-medium hover:bg-gray-900">Add</button>
  <% end %>
</div>
