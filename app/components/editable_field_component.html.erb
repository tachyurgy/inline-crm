<div data-controller="inline-edit" class="group relative" id="<%= dom_id(record, field) %>">
  <div data-inline-edit-target="display"
       data-action="click->inline-edit#edit"
       class="cursor-pointer rounded px-2 py-1 hover:bg-gray-100 transition-colors duration-150 <%= 'text-gray-400 italic' if blank? %>">
    <span class="text-xs font-medium text-gray-500 block"><%= label %></span>
    <span class="text-sm"><%= display_value %></span>
  </div>

  <div data-inline-edit-target="form" class="hidden">
    <%= form_with(model: record, url: url, method: :patch, data: { action: "turbo:submit-end->inline-edit#success" }) do |f| %>
      <label class="text-xs font-medium text-gray-500 block px-2"><%= label %></label>
      <% if input_type == :textarea %>
        <%= f.text_area field, class: "w-full border border-blue-400 rounded px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", rows: 3, data: { action: "keydown->inline-edit#submit blur->inline-edit#cancel" } %>
      <% elsif input_type == :number %>
        <%= f.number_field field, class: "w-full border border-blue-400 rounded px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", step: "0.01", data: { action: "keydown->inline-edit#submit blur->inline-edit#cancel" } %>
      <% elsif input_type == :select %>
        <%= f.select field, Deal::STAGES.map { |s| [s.humanize, s] }, {}, class: "w-full border border-blue-400 rounded px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", data: { action: "change->inline-edit#submit" } %>
      <% else %>
        <%= f.text_field field, class: "w-full border border-blue-400 rounded px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", data: { action: "keydown->inline-edit#submit blur->inline-edit#cancel" } %>
      <% end %>
    <% end %>
  </div>
</div>
